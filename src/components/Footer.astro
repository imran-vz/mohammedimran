---
import { footerSocialLinks, primaryNavLinks } from '../config/navigation';
import { siteMeta } from '../config/siteMeta';
---

<footer class="footer">
    <div class="footer-content">
        <div>
            <h2 class="footer-title">
                LET'S BUILD
                <br />
                <span>SOMETHING</span>
                <br />
                TOGETHER
            </h2>
        </div>
        <div>
            <h3 class="footer-section-title">Connect</h3>
            <div class="footer-links">
                {footerSocialLinks
                    .filter((link) => link.type !== 'twitter')
                    .map((link) => (
                        <a
                            href={link.href}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="footer-link"
                        >
                            {link.label}
                        </a>
                    ))}
                <a href={`mailto:${siteMeta.email}`} class="footer-link">
                    Email
                </a>
            </div>
        </div>
        <div>
            <h3 class="footer-section-title">Navigate</h3>
            <div class="footer-links">
                {primaryNavLinks
                    .filter((link) => !link.href.startsWith('mailto:'))
                    .map((link) => (
                        <a href={link.href} class="footer-link">
                            {link.label}
                        </a>
                    ))}
                <span class="footer-link">{siteMeta.location.locality}, {siteMeta.location.country}</span>
            </div>
        </div>
    </div>
</footer>
