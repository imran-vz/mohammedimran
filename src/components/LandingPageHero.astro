---
import { Image } from 'astro:assets';
import mohammedimran from '../assets/mohammedimran.webp';
---

<div
    class="relative isolate min-h-svh flex items-center justify-center lg:px-8"
>
    <div class="mx-auto max-w-4xl px-6 py-16 sm:py-24 lg:px-8">
        <div class="text-center space-y-8">
            <!-- Profile Image -->
            <div class="flex justify-center mb-8">
                <Image
                    src={mohammedimran}
                    format={"webp"}
                    width={300}
                    height={300}
                    densities={[1, 1.5, 2]}
                    class="object-cover shrink-0 w-36 h-36 sm:w-44 sm:h-44 md:w-52 md:h-52 rounded-full border-2 border-skin-accent/30 shadow-xl"
                    title="Imran"
                    loading="eager"
                    fetchpriority={"high"}
                    alt="Imran"
                />
            </div>

            <!-- Typography -->
            <div class="space-y-5">
                <h1
                    class="text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight text-skin-base"
                >
                    Imran
                </h1>

                <p class="text-xl sm:text-2xl font-medium text-skin-base/70">
                    Senior Full Stack Developer
                </p>

                <!-- Tech Stack Badges -->
                <div class="flex flex-wrap items-center justify-center gap-2 pt-2">
                    <span class="inline-flex items-center rounded-full border border-skin-accent/40 bg-skin-accent/5 px-4 py-1.5 text-sm font-medium text-skin-accent">
                        React
                    </span>
                    <span class="inline-flex items-center rounded-full border border-skin-accent/40 bg-skin-accent/5 px-4 py-1.5 text-sm font-medium text-skin-accent">
                        TypeScript
                    </span>
                    <span class="inline-flex items-center rounded-full border border-skin-accent/40 bg-skin-accent/5 px-4 py-1.5 text-sm font-medium text-skin-accent">
                        GoLang
                    </span>
                </div>

                <!-- Location -->
                <div class="flex items-center justify-center gap-2 text-skin-base/60 text-sm">
                    <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                    </svg>
                    <span>Bengaluru, India</span>
                    <span class="text-skin-base/40">|</span>
                    <span>Available Remotely</span>
                </div>

                <p
                    class="mx-auto max-w-xl text-base sm:text-lg leading-relaxed text-skin-base/70"
                >
                    5+ years building scalable web applications with modern technologies.
                    Passionate about clean code, performance optimization, and open source.
                </p>
            </div>

            <!-- CTA Buttons -->
            <div
                class="flex flex-col sm:flex-row items-center justify-center gap-3 pt-4"
            >
                <a
                    href="https://github.com/imran-vz"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-2 bg-skin-accent text-white px-6 py-3 text-sm font-medium rounded-lg hover:bg-skin-accent/90 transition-colors duration-200 focus-outline w-full sm:w-auto justify-center"
                >
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                        <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"></path>
                    </svg>
                    GitHub
                </a>
                <a
                    href="https://www.linkedin.com/in/m0hammedimran/"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-2 border border-skin-base/30 text-skin-base px-6 py-3 text-sm font-medium rounded-lg hover:bg-skin-base/5 transition-colors duration-200 focus-outline w-full sm:w-auto justify-center"
                >
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"></path>
                    </svg>
                    LinkedIn
                </a>
            </div>
        </div>
    </div>
</div>
