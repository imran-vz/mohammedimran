---
import type { FeaturedProject } from '../utils/fetch-featured-projects';

export interface Props {
	project: FeaturedProject;
	index?: number;
}

const { project, index = 0 } = Astro.props;
const animationDelay = `${(index % 3) * 0.1 + 0.1}s`;
---

<article
	class="featured-card group relative overflow-hidden rounded-2xl border border-skin-border bg-skin-card p-8 transition-all duration-300 hover:border-skin-accent/60"
	style={`animation-delay: ${animationDelay}`}
>
	<!-- Gradient overlay on hover -->
	<div
		class="absolute inset-0 bg-linear-to-br from-skin-accent/5 via-transparent to-skin-accent-secondary/5 opacity-0 transition-opacity duration-300 group-hover:opacity-100"
	>
	</div>

	<div class="relative z-10 flex flex-col gap-y-6 h-full">
		<!-- Header -->
		<div class="flex items-center justify-between gap-3">
			<div class="flex-1">
				<h3
					class="text-2xl font-bold text-skin-base group-hover:text-skin-accent transition-colors duration-200"
				>
					<a
						href={project.url}
						target="_blank"
						rel="noopener noreferrer"
						class="hover:underline"
					>
						{project.name}
					</a>
				</h3>
			</div>
			<a
				href={project.url}
				target="_blank"
				rel="noopener noreferrer"
				class="text-skin-base/60 transition-colors hover:text-skin-accent"
				aria-label="View on GitHub"
			>
				<svg
					class="h-6 w-6"
					fill="currentColor"
					viewBox="0 0 24 24"
					aria-hidden="true"
				>
					<path
						fill-rule="evenodd"
						d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
						clip-rule="evenodd"></path>
				</svg>
			</a>
		</div>

		<!-- Description -->
		<div class=" flex-1">

    		<p class="text-base text-skin-base/80 leading-relaxed">
    			{project.description}
    		</p>
		</div>

		<!-- Stats Grid -->
		<div class="grid grid-cols-2 sm:grid-cols-4 gap-4 py-4 border-y border-skin-border/50">
			<!-- Stars -->
			<div class="flex flex-col items-center justify-center space-y-1 group/stat">
				<svg
					class="h-5 w-5 text-skin-accent group-hover/stat:scale-110 transition-transform"
					fill="currentColor"
					viewBox="0 0 20 20"
				>
					<path
						d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"
					></path>
				</svg>
				<span class="text-lg font-bold text-skin-base">{project.stars}</span>
				<span class="text-xs text-skin-base/60">Stars</span>
			</div>

			<!-- Forks -->
			<div class="flex flex-col items-center justify-center space-y-1 group/stat">
				<svg
					class="h-5 w-5 text-skin-accent group-hover/stat:scale-110 transition-transform"
					fill="currentColor"
					viewBox="0 0 20 20"
				>
					<path
						fill-rule="evenodd"
						d="M7.707 3.293a1 1 0 010 1.414L5.414 7H11a7 7 0 017 7v2a1 1 0 11-2 0v-2a5 5 0 00-5-5H5.414l2.293 2.293a1 1 0 11-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z"
						clip-rule="evenodd"></path>
				</svg>
				<span class="text-lg font-bold text-skin-base">{project.forks}</span>
				<span class="text-xs text-skin-base/60">Forks</span>
			</div>

			<!-- Watchers -->
			<div class="flex flex-col items-center justify-center space-y-1 group/stat">
				<svg
					class="h-5 w-5 text-skin-accent group-hover/stat:scale-110 transition-transform"
					fill="currentColor"
					viewBox="0 0 20 20"
				>
					<path d="M10 12a2 2 0 100-4 2 2 0 000 4z"></path>
					<path
						fill-rule="evenodd"
						d="M.458 10C1.732 5.943 5.522 3 10 3s8.268 2.943 9.542 7c-1.274 4.057-5.064 7-9.542 7S1.732 14.057.458 10zM14 10a4 4 0 11-8 0 4 4 0 018 0z"
						clip-rule="evenodd"></path>
				</svg>
				<span class="text-lg font-bold text-skin-base">{project.watchers}</span>
				<span class="text-xs text-skin-base/60">Watchers</span>
			</div>

			<!-- Open Issues -->
			<div class="flex flex-col items-center justify-center space-y-1 group/stat">
				<svg
					class="h-5 w-5 text-skin-accent group-hover/stat:scale-110 transition-transform"
					fill="currentColor"
					viewBox="0 0 20 20"
				>
					<path
						fill-rule="evenodd"
						d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z"
						clip-rule="evenodd"></path>
				</svg>
				<span class="text-lg font-bold text-skin-base">{project.openIssues}</span>
				<span class="text-xs text-skin-base/60">Issues</span>
			</div>
		</div>

		<!-- Language Breakdown -->
		{
			project.languages && project.languages.length > 0 && (
				<div class="space-y-3">
					<h4 class="text-sm font-semibold text-skin-base">Languages</h4>
					<!-- Language Bar -->
					<div class="flex gap-0.5 h-2.5 rounded-full overflow-hidden bg-skin-card-muted">
						{project.languages.map((lang) => (
							 <div
								class="h-full transition-all hover:opacity-80"
								style={`width: ${lang.percentage.toFixed(2)}%; background-color: ${lang.color}`}
								title={`${lang.name} ${lang.percentage.toFixed(1)}%`}
							/>
						))}
					</div>
					<!-- Language Labels -->
					<div class="flex flex-wrap gap-3 text-xs">
						{project.languages.map((lang) => (
							<span class="flex items-center gap-1.5 text-skin-base/70">
								<span
									class="w-2.5 h-2.5 rounded-full"
									style={`background-color: ${lang.color}`}
								/>
								<span class="font-medium">{lang.name}</span>
								<span class="text-skin-base/50">{lang.percentage>1? lang.percentage.toFixed(1):"<1"}%</span>
							</span>
						))}
					</div>
				</div>
			)
		}

		<!-- Topics -->
		{
			project.topics && project.topics.length > 0 && (
				<div class="flex flex-wrap gap-2">
					{project.topics.slice(0, 5).map((topic) => (
						<span class="rounded-md bg-skin-accent/10 px-2.5 py-1 text-xs text-skin-accent font-medium">
							#{topic}
						</span>
					))}
				</div>
			)
		}

		<!-- Footer with Links and Last Update -->
		<div class="flex flex-col items-start sm:items-center justify-between gap-4 pt-4 border-t border-skin-border/50">
			<div class="flex flex-wrap gap-3">
				<a
					href={project.url}
					target="_blank"
					rel="noopener noreferrer"
					class="inline-flex items-center gap-2 rounded-lg bg-skin-accent/10 px-4 py-2 text-sm font-medium text-skin-accent transition-all hover:bg-skin-accent hover:text-white"
				>
					<svg class="h-4 w-4" fill="currentColor" viewBox="0 0 20 20">
						<path
							d="M11 3a1 1 0 100 2h2.586l-6.293 6.293a1 1 0 101.414 1.414L15 6.414V9a1 1 0 102 0V4a1 1 0 00-1-1h-5z"
						></path>
						<path
							d="M5 5a2 2 0 00-2 2v8a2 2 0 002 2h8a2 2 0 002-2v-3a1 1 0 10-2 0v3H5V7h3a1 1 0 000-2H5z"
						></path>
					</svg>
					View Code
				</a>
				{
					project.homepage && (
						<a
							href={project.homepage}
							target="_blank"
							rel="noopener noreferrer"
							class="inline-flex items-center gap-2 rounded-lg border border-skin-accent/30 px-4 py-2 text-sm font-medium text-skin-accent transition-all hover:border-skin-accent hover:bg-skin-accent/10"
						>
							<svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path
									stroke-linecap="round"
									stroke-linejoin="round"
									stroke-width="2"
									d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"
								/>
							</svg>
							Live Demo
						</a>
					)
				}
			</div>
			<div class="text-xs text-skin-base/50">
				Updated {project.lastCommitDateFormatted}
			</div>
		</div>
	</div>
</article>

<style>
	@keyframes slideUp {
		from {
			opacity: 0;
			transform: translateY(30px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	.featured-card {
		animation: slideUp 0.6s ease-out;
		animation-fill-mode: both;
		min-height: 500px;
	}

	.featured-card:hover {
		transform: translateY(-12px);
		box-shadow: 0 25px 50px rgba(var(--color-accent), 0.25);
	}
</style>
