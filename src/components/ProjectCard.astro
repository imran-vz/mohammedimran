---
import type { ProcessedRepo } from '../utils/fetch-github-repos';
import { LANGUAGE_BADGE_CLASSES } from '../config/language-colors';
import GitHubIcon from './icons/GitHubIcon.astro';
import StarIcon from './icons/StarIcon.astro';
import ForkIcon from './icons/ForkIcon.astro';
import ExternalLinkIcon from './icons/ExternalLinkIcon.astro';
import GlobeIcon from './icons/GlobeIcon.astro';

export interface Props {
	project: ProcessedRepo;
}

const { project } = Astro.props;

const languageColor = LANGUAGE_BADGE_CLASSES[project.language] || 'bg-skin-accent-secondary';
---

<article
    class="spotlight-card group relative overflow-hidden rounded-xl border border-skin-border bg-skin-card p-6 transition-all duration-300 hover:-translate-y-1 hover:shadow-lg hover:shadow-skin-accent/20 hover:border-skin-accent/50"
>
    <!-- Gradient overlay on hover -->
    <div
        class="absolute inset-0 bg-linear-to-br from-skin-accent/5 via-transparent to-skin-accent-secondary/5 opacity-0 transition-opacity duration-300 group-hover:opacity-100"
    >
    </div>

    <div class="relative z-10">
        <!-- Header -->
        <div class="mb-4 flex items-start justify-between gap-3">
            <div class="flex-1">
                <div class="mb-2 flex items-center gap-2 flex-wrap">
                    <h3
                        class="text-xl font-bold text-skin-base group-hover:text-skin-accent transition-colors duration-200"
                    >
                        <a
                            href={project.url}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="hover:underline"
                        >
                            {project.name.replace(/-/g, " ").replace(/_/g, " ")}
                        </a>
                    </h3>
                    {
                        project.category === "personal" && (
                            <span class="inline-flex items-center gap-1 rounded-full bg-linear-to-r from-purple-500/20 to-blue-500/20 border border-purple-400/30 px-2.5 py-0.5 text-xs font-semibold text-purple-400">
                                Personal
                            </span>
                        )
                    }
                    {
                        project.category === "oss" && (
                            <span class="inline-flex items-center gap-1 rounded-full bg-linear-to-r from-green-500/20 to-emerald-500/20 border border-green-400/30 px-2.5 py-0.5 text-xs font-semibold text-green-400">
                                OSS Contribution
                            </span>
                        )
                    }
                </div>
                <div class="mt-2 flex flex-wrap items-center gap-3 text-sm">
                    <span
                        class={`inline-flex items-center gap-1 rounded-full px-2 py-1 text-xs font-semibold ${languageColor}`}
                    >
                        {project.language}
                    </span>
                    {
                        project.stars > 0 && (
                            <span class="flex items-center gap-1 text-skin-base/70">
                                <StarIcon />
                                {project.stars}
                            </span>
                        )
                    }
                    {
                        project.forks > 0 && (
                            <span class="flex items-center gap-1 text-skin-base/70">
                                <ForkIcon />
                                {project.forks}
                            </span>
                        )
                    }
                </div>
            </div>
            <a
                href={project.url}
                target="_blank"
                rel="noopener noreferrer"
                class="text-skin-base/60 transition-colors hover:text-skin-accent"
                aria-label="View on GitHub"
            >
                <GitHubIcon />
            </a>
        </div>

        <!-- Description -->
        <p class="mb-4 line-clamp-2 text-sm text-skin-base/80">
            {project.description}
        </p>

        <!-- Topics -->
        {
            project.topics && project.topics.length > 0 && (
                <div class="flex flex-wrap gap-2">
                    {project.topics.slice(0, 4).map((topic) => (
                        <span class="rounded-md bg-skin-accent/10 px-2 py-1 text-xs text-skin-accent">
                            #{topic}
                        </span>
                    ))}
                </div>
            )
        }

        <!-- Links -->
        <div
            class="mt-4 flex flex-wrap gap-3 border-t border-skin-border/50 pt-4"
        >
            <a
                href={project.url}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 rounded-lg bg-skin-accent/10 px-4 py-2 text-sm font-medium text-skin-accent transition-all hover:bg-skin-accent hover:text-white"
            >
                <ExternalLinkIcon />
                View Code
            </a>
            {
                project.homepage && (
                    <a
                        href={project.homepage}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="inline-flex items-center gap-2 rounded-lg border border-skin-accent/30 px-4 py-2 text-sm font-medium text-skin-accent transition-all hover:border-skin-accent hover:bg-skin-accent/10"
                    >
                        <GlobeIcon />
                        Live Demo
                    </a>
                )
            }
        </div>

        <!-- Last updated -->
        <div class="mt-3 text-xs text-skin-base/50">
            Updated {project.lastUpdated}
        </div>
    </div>
</article>
