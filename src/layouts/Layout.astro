---
import { inject } from '@vercel/analytics';
import BackgroundElements from '../components/BackgroundElements.astro';
import Footer from '../components/Footer.astro';
import Navbar from '../components/Navbar.astro';
import { siteMeta } from '../config/siteMeta';

import '../styles/base.css';

// Initialize Vercel Analytics
inject();
export interface Props {
	title?: string;
	description?: string;
	image?: string;
	canonical?: string;
}

const {
	title = siteMeta.defaultTitle,
	description = siteMeta.defaultDescription,
	image = siteMeta.ogImage || siteMeta.logoUrl,
	canonical = siteMeta.siteUrl,
} = Astro.props;

// Structured Data - JSON-LD
const structuredData = {
	'@context': 'https://schema.org',
	'@type': 'Person',
	name: siteMeta.brandShort,
	alternateName: siteMeta.alternateNames,
	jobTitle: 'Senior Full Stack Developer',
	description: siteMeta.defaultDescription,
	url: siteMeta.siteUrl,
	image: siteMeta.logoUrl,
	sameAs: ['https://github.com/imran-vz', 'https://www.linkedin.com/in/m0hammedimran/'],
	knowsAbout: ['React', 'TypeScript', 'GoLang', 'JavaScript', 'Web Development', 'Full Stack Development'],
	address: {
		'@type': 'PostalAddress',
		addressLocality: siteMeta.location.locality,
		addressRegion: siteMeta.location.region,
		addressCountry: siteMeta.location.country,
	},
	worksFor: {
		'@type': 'Organization',
		name: siteMeta.employer,
	},
	email: 'mohammedimran86992@gmail.com',
};

const websiteSchema = {
	'@context': 'https://schema.org',
	'@type': 'WebSite',
	name: siteMeta.brandShort,
	url: siteMeta.siteUrl,
	description: siteMeta.defaultDescription,
	author: {
		'@type': 'Person',
		name: siteMeta.brandLong,
	},
};
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta
            name="viewport"
            content="width=device-width, initial-scale=1, viewport-fit=cover, maximum-scale=5"
        />

        <!-- Performance: Preconnect to external domains -->
        <link rel="preconnect" href="https://api.github.com" />
        <link rel="dns-prefetch" href="https://api.github.com" />

        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="canonical" href={canonical} />
        <meta name="generator" content={Astro.generator} />
        <link rel="manifest" href="/manifest.json" />

        <!-- SEO Meta Tags -->
        <title>{title}</title>
        <meta name="description" content={description} />
        <meta
            name="keywords"
            content="Imran, Imran developer, React developer, TypeScript expert, GoLang developer, Full Stack Developer Bengaluru, imran-vz, Senior Developer India, React Bengaluru, Remote Developer"
        />
        <meta name="author" content={siteMeta.brandLong} />
        <meta name="application-name" content={siteMeta.brandShort} />
        <meta name="apple-mobile-web-app-title" content={siteMeta.brandShort} />
        <link rel="author" href="https://www.linkedin.com/in/m0hammedimran" />
        <meta name="color-scheme" content="dark light" />

        <!-- Twitter Card -->
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:site" content="@m0hammed_imran" />
        <meta name="twitter:creator" content="@m0hammed_imran" />
        <meta name="twitter:title" content={title} />
        <meta name="twitter:description" content={description} />
        <meta name="twitter:image" content={image} />

        <!-- Open Graph -->
        <meta property="og:type" content="website" />
        <meta property="og:url" content={canonical} />
        <meta property="og:site_name" content={siteMeta.brandShort} />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:image" content={image} />
        <meta property="og:image:width" content="1200" />
        <meta property="og:image:height" content="630" />
        <meta property="og:image:alt" content="Imran - Full Stack Developer" />
        <meta property="og:locale" content="en_IN" />

        <!-- Structured Data -->
        <script
            type="application/ld+json"
            set:html={JSON.stringify(structuredData)}
        />
        <script
            type="application/ld+json"
            set:html={JSON.stringify(websiteSchema)}
        />

        <link rel="sitemap" href="/sitemap-index.xml" />

        <slot name="head" />

        <style>
            html {
                scroll-behavior: smooth;
                font-display: swap;
            }
        </style>

        <meta name="theme-color" content="#FAF8F5" />
        <script is:inline src="/toggle-theme.js"></script>
        <script>
            // Spotlight Effect for Cards
            const cards = document.querySelectorAll('.spotlight-card');
        
            document.addEventListener('mousemove', (e) => {
                cards.forEach(card => {
                    const rect = card.getBoundingClientRect();
                    const x = e.clientX - rect.left;
                    const y = e.clientY - rect.top;
        
                    (card as HTMLElement).style.setProperty('--mouse-x', `${x}px`);
                    (card as HTMLElement).style.setProperty('--mouse-y', `${y}px`);
                });
            });
        </script>
        <style is:global>
            .spotlight-card {
                position: relative;
                overflow: hidden;
            }
        
            /* The glowing border effect */
            .spotlight-card::before {
                content: "";
                position: absolute;
                inset: 0;
                background: radial-gradient(
                    600px circle at var(--mouse-x) var(--mouse-y),
                    rgba(var(--color-accent), 0.06),
                    transparent 40%
                );
                opacity: 0;
                transition: opacity 0.5s;
                z-index: 0;
                pointer-events: none;
            }
        
            /* The border highlight */
            .spotlight-card::after {
                content: "";
                position: absolute;
                inset: -1px;
                background: radial-gradient(
                    300px circle at var(--mouse-x) var(--mouse-y),
                    rgba(var(--color-accent), 0.25),
                    transparent 40%
                );
                opacity: 0;
                z-index: -1;
                transition: opacity 0.5s;
                border-radius: inherit;
            }
        
            .spotlight-card:hover::before,
            .spotlight-card:hover::after {
                opacity: 1;
            }
        </style>

    </head>

    <body
        class="flex min-h-svh flex-col bg-skin-fill font-mono text-skin-base selection:bg-skin-accent selection:bg-opacity-70 selection:text-white"
    >
        <BackgroundElements />
        <Navbar />
        <slot />
        <Footer />
    </body>
</html>
