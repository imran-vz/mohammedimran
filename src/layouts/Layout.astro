---
import { inject } from '@vercel/analytics';
import Footer from '../components/Footer.astro';
import Navbar from '../components/Navbar.astro';
import { buildPersonSchema, buildWebsiteSchema } from '../config/schema';
import { siteMeta } from '../config/siteMeta';

inject();

export interface Props {
	title?: string;
	description?: string;
	image?: string;
	canonical?: string;
}

const {
	title = siteMeta.defaultTitle,
	description = siteMeta.defaultDescription,
	image = siteMeta.ogImage || siteMeta.logoUrl,
	canonical = siteMeta.siteUrl,
} = Astro.props;

const structuredData = buildPersonSchema();
const websiteSchema = buildWebsiteSchema();
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta
            name="viewport"
            content="width=device-width, initial-scale=1, viewport-fit=cover, maximum-scale=5"
        />

        <link rel="preconnect" href="https://api.github.com" />
        <link rel="dns-prefetch" href="https://api.github.com" />

        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="canonical" href={canonical} />
        <meta name="generator" content={Astro.generator} />
        <link rel="manifest" href="/manifest.json" />

        <title>{title}</title>
        <meta name="description" content={description} />
        <meta
            name="keywords"
            content="Imran, Imran developer, React developer, TypeScript expert, GoLang developer, Full Stack Developer Bengaluru, imran-vz, Senior Developer India, React Bengaluru, Remote Developer"
        />
        <meta name="author" content={siteMeta.brandLong} />
        <meta name="application-name" content={siteMeta.brandShort} />
        <meta name="apple-mobile-web-app-title" content={siteMeta.brandShort} />
        <link rel="author" href="https://www.linkedin.com/in/m0hammedimran" />
        <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
        <meta name="googlebot" content="index, follow" />
        <meta name="color-scheme" content="light" />

        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:site" content="@m0hammed_imran" />
        <meta name="twitter:creator" content="@m0hammed_imran" />
        <meta name="twitter:title" content={title} />
        <meta name="twitter:description" content={description} />
        <meta name="twitter:image" content={image} />

        <meta property="og:type" content="website" />
        <meta property="og:url" content={canonical} />
        <meta property="og:site_name" content={siteMeta.brandShort} />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:image" content={image} />
        <meta property="og:image:width" content="1200" />
        <meta property="og:image:height" content="630" />
        <meta property="og:image:alt" content="Imran - Full Stack Developer" />
        <meta property="og:locale" content="en_IN" />

        <script
            type="application/ld+json"
            set:html={JSON.stringify(structuredData)}
        />
        <script
            type="application/ld+json"
            set:html={JSON.stringify(websiteSchema)}
        />

        <link rel="sitemap" href="/sitemap-index.xml" />

        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link rel="dns-prefetch" href="https://fonts.googleapis.com" />
        <link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Anton&display=swap" rel="stylesheet" />

        <slot name="head" />

        <meta name="theme-color" content="#ffff00" />

        <style is:global>
            * {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
            }

			:root {
				--black: #000000;
				--white: #ffffff;
				--yellow: #ffff00;
				--red: #ff0000;
				--blue: #0000ff;
				--gray: #888888;
				--page-bg: #fbfbfa;
				--page-ink: #37352f;
				--page-muted: #787774;
				--page-soft: #f1f1ef;
				--page-line: #e9e9e7;
				--page-hover: #f7f7f5;
			}

            html {
                scroll-behavior: smooth;
            }

			body {
				font-family: 'Space Mono', monospace;
				background: var(--page-bg);
				color: var(--page-ink);
				min-height: 100vh;
				overflow-x: hidden;
				cursor: text;
			}

			::selection {
				background: #dbeafe;
				color: var(--page-ink);
			}

            a {
                color: inherit;
                text-decoration: none;
            }

            .border-brutal {
                border: 4px solid var(--black);
            }

			.header {
				position: sticky;
				top: 0;
				z-index: 20;
				border-bottom: 1px solid var(--page-line);
				padding: 10px 18px;
				display: flex;
				justify-content: space-between;
				align-items: center;
				flex-wrap: wrap;
				gap: 12px;
				background: rgba(251, 251, 250, 0.86);
				backdrop-filter: blur(16px);
			}

            .skip-link {
                position: absolute;
                top: -100%;
                left: 16px;
                z-index: 10000;
                background: var(--yellow);
                color: var(--black);
                border: 2px solid var(--black);
                padding: 8px 12px;
            }

            .skip-link:focus {
                top: 16px;
            }

			.logo {
				font-family: 'Space Mono', monospace;
				font-size: 13px;
				font-weight: 700;
				letter-spacing: 0;
				color: var(--page-muted);
			}

			.nav-links {
				display: flex;
				gap: 6px;
			}

			.nav-link {
				border-radius: 6px;
				padding: 6px 8px;
				color: var(--page-muted);
				font-size: 12px;
				text-transform: none;
				letter-spacing: 0;
				position: relative;
			}

			.nav-link:hover {
				background: var(--page-soft);
				color: var(--page-ink);
			}

			.nav-link::after {
				display: none;
			}

			#main-content {
				width: min(100%, 900px);
				margin: 0 auto;
				padding: 72px 36px 120px;
			}

			.section {
				width: min(100%, 720px);
				margin: 0 auto;
				border: 0;
				padding: 22px 0 4px;
			}

			.section-header {
				display: flex;
				justify-content: flex-start;
				align-items: center;
				gap: 10px;
				padding: 0;
				border: 0;
				margin-bottom: 8px;
				background: transparent;
			}

			.section-title {
				font-family: ui-sans-serif, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
				font-size: 1.28rem;
				font-weight: 700;
				text-transform: none;
				letter-spacing: -0.02em;
			}

			.section-count {
				border-radius: 5px;
				padding: 2px 7px;
				background: var(--page-soft);
				font-family: ui-sans-serif, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
				font-size: 12px;
				line-height: 1.4;
				color: var(--page-muted);
			}

			.footer {
				border-top: 1px solid var(--page-line);
				background: var(--page-bg);
				color: var(--page-muted);
				padding: 36px 40px;
			}

			.footer-content {
				width: min(100%, 720px);
				max-width: 720px;
				margin: 0 auto;
				display: grid;
				grid-template-columns: 1fr 1fr;
				gap: 28px;
			}

			.footer-content > div:first-child {
				display: none;
			}

            @media (max-width: 900px) {
                .footer-content {
                    grid-template-columns: 1fr;
                    gap: 40px;
                }
            }

            .footer-title {
                font-family: 'Anton', sans-serif;
                font-size: 4rem;
                text-transform: uppercase;
                line-height: 1;
            }

            .footer-title span {
                color: var(--yellow);
            }

			.footer-section-title {
				font-family: ui-sans-serif, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
				font-size: 13px;
				text-transform: uppercase;
				letter-spacing: 0;
				color: var(--page-muted);
				margin-bottom: 12px;
			}

            .footer-links {
                display: flex;
                flex-direction: column;
                gap: 15px;
            }

			.footer-link {
				font-family: ui-sans-serif, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
				font-size: 13px;
				transition: color 0.18s ease;
			}

			.footer-link:hover {
				color: var(--page-ink);
			}

			.noise {
				display: none;
			}

			@media (max-width: 600px) {
				.header { padding: 10px 12px; }
				.nav-links { gap: 2px; }
				#main-content { padding: 44px 20px 80px; }
				.footer { padding: 32px 20px; }
				.footer-content { grid-template-columns: 1fr; }
			}
        </style>
    </head>

    <body>
        <div class="noise"></div>
        <Navbar />
        <slot />
        <Footer />
    </body>
</html>
