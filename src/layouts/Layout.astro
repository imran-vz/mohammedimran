---
import { inject } from '@vercel/analytics';
import Footer from '../components/Footer.astro';
import Navbar from '../components/Navbar.astro';
import { buildPersonSchema, buildWebsiteSchema } from '../config/schema';
import { siteMeta } from '../config/siteMeta';

inject();

export interface Props {
	title?: string;
	description?: string;
	image?: string;
	canonical?: string;
}

const {
	title = siteMeta.defaultTitle,
	description = siteMeta.defaultDescription,
	image = siteMeta.ogImage || siteMeta.logoUrl,
	canonical = siteMeta.siteUrl,
} = Astro.props;

const structuredData = buildPersonSchema();
const websiteSchema = buildWebsiteSchema();
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta
            name="viewport"
            content="width=device-width, initial-scale=1, viewport-fit=cover, maximum-scale=5"
        />

        <link rel="preconnect" href="https://api.github.com" />
        <link rel="dns-prefetch" href="https://api.github.com" />

        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="canonical" href={canonical} />
        <meta name="generator" content={Astro.generator} />
        <link rel="manifest" href="/manifest.json" />

        <title>{title}</title>
        <meta name="description" content={description} />
        <meta
            name="keywords"
            content="Imran, Imran developer, React developer, TypeScript expert, GoLang developer, Full Stack Developer Bengaluru, imran-vz, Senior Developer India, React Bengaluru, Remote Developer"
        />
        <meta name="author" content={siteMeta.brandLong} />
        <meta name="application-name" content={siteMeta.brandShort} />
        <meta name="apple-mobile-web-app-title" content={siteMeta.brandShort} />
        <link rel="author" href="https://www.linkedin.com/in/m0hammedimran" />
        <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
        <meta name="googlebot" content="index, follow" />
        <meta name="color-scheme" content="light" />

        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:site" content="@m0hammed_imran" />
        <meta name="twitter:creator" content="@m0hammed_imran" />
        <meta name="twitter:title" content={title} />
        <meta name="twitter:description" content={description} />
        <meta name="twitter:image" content={image} />

        <meta property="og:type" content="website" />
        <meta property="og:url" content={canonical} />
        <meta property="og:site_name" content={siteMeta.brandShort} />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:image" content={image} />
        <meta property="og:image:width" content="1200" />
        <meta property="og:image:height" content="630" />
        <meta property="og:image:alt" content="Imran - Full Stack Developer" />
        <meta property="og:locale" content="en_IN" />

        <script
            type="application/ld+json"
            set:html={JSON.stringify(structuredData)}
        />
        <script
            type="application/ld+json"
            set:html={JSON.stringify(websiteSchema)}
        />

        <link rel="sitemap" href="/sitemap-index.xml" />

        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link rel="dns-prefetch" href="https://fonts.googleapis.com" />
        <link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Anton&display=swap" rel="stylesheet" />

        <slot name="head" />

        <meta name="theme-color" content="#ffff00" />

        <style is:global>
            * {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
            }

            :root {
                --black: #000000;
                --white: #ffffff;
                --yellow: #ffff00;
                --red: #ff0000;
                --blue: #0000ff;
                --gray: #888888;
            }

            html {
                scroll-behavior: smooth;
            }

            body {
                font-family: 'Space Mono', monospace;
                background: var(--white);
                color: var(--black);
                min-height: 100vh;
                overflow-x: hidden;
                cursor: crosshair;
            }

            ::selection {
                background: var(--yellow);
                color: var(--black);
            }

            a {
                color: inherit;
                text-decoration: none;
            }

            .border-brutal {
                border: 4px solid var(--black);
            }

            .header {
                border-bottom: 4px solid var(--black);
                padding: 20px;
                display: flex;
                justify-content: space-between;
                align-items: center;
                flex-wrap: wrap;
                gap: 20px;
            }

            .skip-link {
                position: absolute;
                top: -100%;
                left: 16px;
                z-index: 10000;
                background: var(--yellow);
                color: var(--black);
                border: 2px solid var(--black);
                padding: 8px 12px;
            }

            .skip-link:focus {
                top: 16px;
            }

            .logo {
                font-family: 'Anton', sans-serif;
                font-size: 1.5rem;
                letter-spacing: 0.1em;
            }

            .nav-links {
                display: flex;
                gap: 30px;
            }

            .nav-link {
                font-size: 14px;
                text-transform: uppercase;
                letter-spacing: 0.1em;
                position: relative;
            }

            .nav-link::after {
                content: '';
                position: absolute;
                bottom: -4px;
                left: 0;
                width: 0;
                height: 2px;
                background: var(--black);
                transition: width 0.3s;
            }

            .nav-link:hover::after {
                width: 100%;
            }

            .section {
                border-bottom: 4px solid var(--black);
            }

            .section-header {
                display: flex;
                justify-content: space-between;
                align-items: center;
                padding: 30px 40px;
                border-bottom: 4px solid var(--black);
                background: var(--white);
            }

            .section-title {
                font-family: 'Anton', sans-serif;
                font-size: 3rem;
                text-transform: uppercase;
                letter-spacing: 0.05em;
            }

            .section-count {
                font-family: 'Anton', sans-serif;
                font-size: 5rem;
                line-height: 1;
                color: var(--gray);
            }

            .footer {
                background: var(--black);
                color: var(--white);
                padding: 80px 40px;
            }

            .footer-content {
                max-width: 1400px;
                margin: 0 auto;
                display: grid;
                grid-template-columns: 2fr 1fr 1fr;
                gap: 60px;
            }

            @media (max-width: 900px) {
                .footer-content {
                    grid-template-columns: 1fr;
                    gap: 40px;
                }
            }

            .footer-title {
                font-family: 'Anton', sans-serif;
                font-size: 4rem;
                text-transform: uppercase;
                line-height: 1;
            }

            .footer-title span {
                color: var(--yellow);
            }

            .footer-section-title {
                font-size: 11px;
                text-transform: uppercase;
                letter-spacing: 0.15em;
                color: var(--gray);
                margin-bottom: 20px;
            }

            .footer-links {
                display: flex;
                flex-direction: column;
                gap: 15px;
            }

            .footer-link {
                font-size: 1rem;
                transition: color 0.3s;
            }

            .footer-link:hover {
                color: var(--yellow);
            }

            .noise {
                position: fixed;
                inset: 0;
                pointer-events: none;
                z-index: 9999;
                opacity: 0.03;
                background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
            }

            @media (max-width: 600px) {
                .header { padding: 16px; }
                .nav-links { gap: 16px; }
                .section-header { padding: 16px 20px; }
                .section-title { font-size: 1.75rem; }
                .section-count { font-size: 2.5rem; }
                .footer { padding: 40px 20px; }
                .footer-title { font-size: 2.5rem; }
            }
        </style>
    </head>

    <body>
        <div class="noise"></div>
        <Navbar />
        <slot />
        <Footer />
    </body>
</html>
