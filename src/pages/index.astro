---
import imranWebp from '../assets/imran.webp';
import Layout from '../layouts/Layout.astro';
import { siteMeta } from '../config/siteMeta';

// SEO Configuration
const seo = {
	title: 'Imran | Senior Full Stack Developer | React, TypeScript, Go',
	description:
		'Imran - Senior Full Stack Developer with 5+ years experience in React, TypeScript, Go, and Rust. Building data-intensive applications at Thoughtseed. Based in Bengaluru, available remotely.',
	image: siteMeta.ogImage,
	url: siteMeta.siteUrl,
	keywords:
		'Imran, Mohammed Imran, Mohammed Imran developer, Full Stack Developer, React Developer, TypeScript Expert, Go Developer, Rust Developer, Bengaluru Developer, Senior Developer India, imran-vz, Web Developer, Software Engineer',
};

const professionalServiceSchema = {
	'@context': 'https://schema.org',
	'@type': 'ProfessionalService',
	image: imranWebp.src,
	name: 'Imran - Full Stack Development',
	description: 'Full Stack Development services specializing in React, TypeScript, Go, and Rust',
	url: siteMeta.siteUrl,
	areaServed: 'Worldwide',
	serviceType: ['Web Development', 'Full Stack Development', 'Software Engineering'],
};

const projects = [
	{
		name: 'SEER',
		description: 'Tauri desktop app for media file management, metadata editing & re-encoding',
		tech: ['Rust', 'TypeScript', 'React', 'FFmpeg'],
		url: 'https://github.com/imran-vz/seer',
		number: '01',
	},
	{
		name: 'COCOACOMAA STORE',
		description: 'E-commerce storefront for custom dessert ordering with product catalog, cart & checkout',
		tech: ['TypeScript', 'React', 'Vercel'],
		url: 'https://github.com/imran-vz/cocoacomaastore',
		number: '02',
	},
	{
		name: 'GOSQLIT',
		description: 'Terminal UI SQL client with encrypted credentials & multi-database support',
		tech: ['Go', 'Bubble Tea', 'PostgreSQL'],
		url: 'https://github.com/imran-vz/gosqlit',
		number: '03',
	},
];

const skills = ['REACT', 'TYPESCRIPT', 'GO', 'RUST', 'NODE.JS', 'POSTGRESQL', 'NEXT.JS', 'TAURI'];
---

<Layout
    title={seo.title}
    description={seo.description}
    image={seo.image}
    canonical={seo.url}
>
    <Fragment slot="head">
    <meta name="title" content={seo.title} />
    <meta name="keywords" content={seo.keywords} />
    <meta name="twitter:image:alt" content="Imran - Full Stack Developer" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="format-detection" content="telephone=no" />
    <meta name="geo.region" content="IN-KA" />
    <meta name="geo.placename" content="Bengaluru" />
    <meta name="geo.position" content="12.9716;77.5946" />
    <meta name="ICBM" content="12.9716, 77.5946" />
    <script type="application/ld+json" set:html={JSON.stringify(professionalServiceSchema)} />
    <style is:global>
        /* Hero */
        .hero {
            display: grid;
            grid-template-columns: 1fr 1fr;
            min-height: 80vh;
        }

        @media (max-width: 900px) {
            .hero {
                grid-template-columns: 1fr;
            }
        }

        .hero-left {
            border-right: 4px solid var(--black);
            padding: 60px 40px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            background: var(--yellow);
        }

        @media (max-width: 900px) {
            .hero-left {
                border-right: none;
                border-bottom: 4px solid var(--black);
            }
        }

        .hero-title {
            font-family: 'Anton', sans-serif;
            font-size: clamp(4rem, 15vw, 12rem);
            line-height: 0.9;
            letter-spacing: -0.02em;
            text-transform: uppercase;
        }

        .hero-title span {
            display: block;
        }

        .hero-right {
            padding: 60px 40px;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
        }

        .hero-description {
            font-size: 1.25rem;
            line-height: 1.8;
            max-width: 500px;
        }

        .hero-meta {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 30px;
            margin-top: 40px;
        }

        .meta-item {
            border-top: 2px solid var(--black);
            padding-top: 15px;
        }

        .meta-label {
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 0.15em;
            color: var(--gray);
            margin-bottom: 8px;
        }

        .meta-value {
            font-size: 1rem;
            font-weight: 700;
        }

        /* Marquee */
        .marquee-container {
            background: var(--black);
            color: var(--white);
            padding: 20px 0;
            overflow: hidden;
            border-bottom: 4px solid var(--black);
        }

        .marquee {
            display: flex;
            animation: marquee 30s linear infinite;
        }

        .marquee-content {
            display: flex;
            gap: 60px;
            padding-right: 60px;
            white-space: nowrap;
        }

        .marquee-item {
            font-family: 'Anton', sans-serif;
            font-size: 2rem;
            text-transform: uppercase;
            letter-spacing: 0.1em;
        }

        @keyframes marquee {
            0% { transform: translateX(0); }
            100% { transform: translateX(-50%); }
        }

        /* Projects */
        .projects-list {
            display: flex;
            flex-direction: column;
        }

        .project-item {
            display: grid;
            grid-template-columns: 100px 1fr 2fr auto;
            gap: 40px;
            padding: 40px;
            border-bottom: 2px solid var(--black);
            transition: all 0.3s;
            align-items: center;
        }

        @media (max-width: 900px) {
            .project-item {
                grid-template-columns: 1fr;
                gap: 20px;
            }
        }

        .project-item:last-child {
            border-bottom: none;
        }

        .project-item:hover {
            background: var(--yellow);
        }

        .project-number {
            font-family: 'Anton', sans-serif;
            font-size: 4rem;
            color: var(--gray);
            transition: color 0.3s;
        }

        .project-item:hover .project-number {
            color: var(--black);
        }

        .project-name {
            font-family: 'Anton', sans-serif;
            font-size: 2.5rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        .project-description {
            font-size: 14px;
            line-height: 1.8;
            color: var(--gray);
        }

        .project-item:hover .project-description {
            color: var(--black);
        }

        .project-arrow {
            font-size: 2rem;
            transition: transform 0.3s;
        }

        .project-item:hover .project-arrow {
            transform: translate(10px, -10px);
        }

        .project-tech {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            margin-top: 15px;
        }

        .tech-tag {
            padding: 5px 12px;
            border: 2px solid var(--black);
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 0.1em;
        }

        /* Skills */
        .skills-section {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
        }

        @media (max-width: 900px) {
            .skills-section {
                grid-template-columns: repeat(2, 1fr);
            }
        }

        @media (max-width: 500px) {
            .skills-section {
                grid-template-columns: 1fr;
            }
        }

        .skill-item {
            padding: 40px;
            border-right: 2px solid var(--black);
            border-bottom: 2px solid var(--black);
            text-align: center;
            transition: all 0.3s;
            font-family: 'Anton', sans-serif;
            font-size: 1.5rem;
            letter-spacing: 0.1em;
        }

        .skill-item:nth-child(4n) {
            border-right: none;
        }

        @media (max-width: 900px) {
            .skill-item:nth-child(4n) {
                border-right: 2px solid var(--black);
            }
            .skill-item:nth-child(2n) {
                border-right: none;
            }
        }

        @media (max-width: 500px) {
            .skill-item {
                border-right: none;
            }
        }

        .skill-item:hover {
            background: var(--black);
            color: var(--yellow);
        }

        /* Work Experience */
        .work-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
        }

        @media (max-width: 700px) {
            .work-grid {
                grid-template-columns: 1fr;
            }
        }

        .work-item {
            padding: 60px 40px;
            border-right: 2px solid var(--black);
            transition: all 0.3s;
        }

        @media (max-width: 700px) {
            .work-item {
                border-right: none;
                border-bottom: 2px solid var(--black);
            }

            .work-item:last-child {
                border-bottom: none;
            }
        }

        .work-item:last-child {
            border-right: none;
        }

        .work-item:hover {
            background: var(--red);
            color: var(--white);
        }

        .work-item:hover a {
            color: var(--yellow);
        }

        .work-company {
            font-family: 'Anton', sans-serif;
            font-size: 3rem;
            text-transform: uppercase;
            margin-bottom: 10px;
        }

        .work-role {
            font-size: 14px;
            text-transform: uppercase;
            letter-spacing: 0.15em;
            margin-bottom: 20px;
            opacity: 0.7;
        }

        .work-description {
            font-size: 14px;
            line-height: 1.8;
        }

        .work-link {
            display: inline-block;
            margin-top: 20px;
            text-decoration: underline;
            text-underline-offset: 4px;
        }
    </style>
    </Fragment>

    <!-- Hero -->
    <main id="main-content">
    <section class="hero">
        <div class="hero-left">
            <h1 class="hero-title">
                <span>IMRAN</span>
            </h1>
        </div>
        <div class="hero-right">
            <div>
                <p class="hero-description">
                    Senior Full Stack Developer specializing in building data-intensive applications. I craft robust systems using modern technologies with a focus on performance and user experience.
                </p>
                <div class="hero-meta">
                    <div class="meta-item">
                        <div class="meta-label">Location</div>
                        <div class="meta-value">Bengaluru, India</div>
                    </div>
                    <div class="meta-item">
                        <div class="meta-label">Current Role</div>
                        <div class="meta-value">@ Thoughtseed</div>
                    </div>
                    <div class="meta-item">
                        <div class="meta-label">Specialization</div>
                        <div class="meta-value">Full Stack</div>
                    </div>
                    <div class="meta-item">
                        <div class="meta-label">Status</div>
                        <div class="meta-value">Available</div>
                    </div>
                </div>
            </div>
        </div>
    </section>
    
    <!-- Skills Marquee -->
    <div class="marquee-container">
        <div class="marquee">
            <div class="marquee-content">
                {[...skills, ...skills].map((skill) => (
                    <span class="marquee-item">{skill}</span>
                ))}
            </div>
            <div class="marquee-content">
                {[...skills, ...skills].map((skill) => (
                    <span class="marquee-item">{skill}</span>
                ))}
            </div>
        </div>
    </div>
    
    <!-- Projects -->
    <section class="section">
        <div class="section-header">
            <h2 class="section-title">Selected Work</h2>
            <span class="section-count">03</span>
        </div>
        <div class="projects-list">
            {projects.map((project) => (
                <a href={project.url} target="_blank" class="project-item">
                    <span class="project-number">{project.number}</span>
                    <h3 class="project-name">{project.name}</h3>
                    <div>
                        <p class="project-description">{project.description}</p>
                        <div class="project-tech">
                            {project.tech.map((t) => (
                                <span class="tech-tag">{t}</span>
                            ))}
                        </div>
                    </div>
                    <span class="project-arrow">↗</span>
                </a>
            ))}
        </div>
    </section>
    
    <!-- Skills Grid -->
    <section class="section">
        <div class="section-header">
            <h2 class="section-title">Technologies</h2>
        </div>
        <div class="skills-section">
            {skills.map((skill) => (
                <div class="skill-item">{skill}</div>
            ))}
        </div>
    </section>
    
    <!-- Work Experience -->
    <section class="section">
        <div class="section-header">
            <h2 class="section-title">Experience</h2>
        </div>
        <div class="work-grid">
            <div class="work-item">
                <h3 class="work-company">Thoughtseed</h3>
                <p class="work-role">Senior Full Stack Developer</p>
                <p class="work-description">
                    Building innovative web applications and data-intensive systems with cutting-edge technologies.
                </p>
                <a href="https://www.thoughtseed.space/" target="_blank" class="work-link">
                    Visit Website →
                </a>
            </div>
            <div class="work-item">
                <h3 class="work-company">Freelance</h3>
                <p class="work-role">Independent Contractor</p>
                <p class="work-description">
                    Developing custom software solutions for clients. Full-stack web applications and system architecture.
                </p>
            </div>
        </div>
    </section>
    
    </main>
</Layout>
