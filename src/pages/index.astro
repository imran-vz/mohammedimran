---
import imranWebp from '../assets/imran.webp';
import Layout from '../layouts/Layout.astro';
import { siteMeta } from '../config/siteMeta';

// SEO Configuration
const seo = {
	title: 'Imran | Senior Full Stack Developer | React, TypeScript, Go',
	description:
		'Imran - Senior Full Stack Developer with 5+ years experience in React, TypeScript, Go, and Rust. Building data-intensive applications at Thoughtseed. Based in Bengaluru, available remotely.',
	image: siteMeta.ogImage,
	url: siteMeta.siteUrl,
	keywords:
		'Imran, Mohammed Imran, Mohammed Imran developer, Full Stack Developer, React Developer, TypeScript Expert, Go Developer, Rust Developer, Bengaluru Developer, Senior Developer India, imran-vz, Web Developer, Software Engineer',
};

const professionalServiceSchema = {
	'@context': 'https://schema.org',
	'@type': 'ProfessionalService',
	image: imranWebp.src,
	name: 'Imran - Full Stack Development',
	description: 'Full Stack Development services specializing in React, TypeScript, Go, and Rust',
	url: siteMeta.siteUrl,
	areaServed: 'Worldwide',
	serviceType: ['Web Development', 'Full Stack Development', 'Software Engineering'],
};

const projects = [
	{
		name: 'SEER',
		description: 'Tauri desktop app for media file management, metadata editing & re-encoding',
		tech: ['Rust', 'TypeScript', 'React', 'FFmpeg'],
		url: 'https://github.com/imran-vz/seer',
		number: '01',
	},
	{
		name: 'COCOACOMAA STORE',
		description: 'E-commerce storefront for custom dessert ordering with product catalog, cart & checkout',
		tech: ['TypeScript', 'React', 'Vercel'],
		url: 'https://github.com/imran-vz/cocoacomaastore',
		number: '02',
	},
	{
		name: 'GOSQLIT',
		description: 'Terminal UI SQL client with encrypted credentials & multi-database support',
		tech: ['Go', 'Bubble Tea', 'PostgreSQL'],
		url: 'https://github.com/imran-vz/gosqlit',
		number: '03',
	},
];

const skills = ['REACT', 'TYPESCRIPT', 'GO', 'RUST', 'NODE.JS', 'POSTGRESQL', 'NEXT.JS', 'TAURI'];
---

<Layout
    title={seo.title}
    description={seo.description}
    image={seo.image}
    canonical={seo.url}
>
    <Fragment slot="head">
    <meta name="title" content={seo.title} />
    <meta name="keywords" content={seo.keywords} />
    <meta name="twitter:image:alt" content="Imran - Full Stack Developer" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="format-detection" content="telephone=no" />
    <meta name="geo.region" content="IN-KA" />
    <meta name="geo.placename" content="Bengaluru" />
    <meta name="geo.position" content="12.9716;77.5946" />
    <meta name="ICBM" content="12.9716, 77.5946" />
    <script type="application/ld+json" set:html={JSON.stringify(professionalServiceSchema)} />
    <style is:global>
        :root {
            --page-bg: #fbfbfa;
            --page-ink: #37352f;
            --page-muted: #787774;
            --page-soft: #f1f1ef;
            --page-line: #e9e9e7;
            --page-hover: #f7f7f5;
        }

        body {
            background: var(--page-bg);
            color: var(--page-ink);
            cursor: text;
        }

        ::selection {
            background: #dbeafe;
            color: var(--page-ink);
        }

        .header {
            position: sticky;
            top: 0;
            z-index: 20;
            border-bottom: 1px solid var(--page-line);
            padding: 10px 18px;
            background: rgba(251, 251, 250, 0.86);
            backdrop-filter: blur(16px);
        }

        .logo {
            font-family: 'Space Mono', monospace;
            font-size: 13px;
            font-weight: 700;
            letter-spacing: 0;
            color: var(--page-muted);
        }

        .nav-links {
            gap: 6px;
        }

        .nav-link {
            border-radius: 6px;
            padding: 6px 8px;
            color: var(--page-muted);
            font-size: 12px;
            letter-spacing: 0;
            text-transform: none;
        }

        .nav-link:hover {
            background: var(--page-soft);
            color: var(--page-ink);
        }

        .nav-link::after {
            display: none;
        }

        #main-content {
            width: min(100%, 900px);
            margin: 0 auto;
            padding: 72px 36px 120px;
        }

        .hero,
        .section {
            width: min(100%, 720px);
            margin: 0 auto;
        }

        .hero {
            display: block;
            min-height: auto;
            padding-bottom: 28px;
        }

        .hero-title {
            font-family: Georgia, 'Times New Roman', serif;
            font-size: clamp(3rem, 9vw, 5.5rem);
            font-weight: 700;
            line-height: 1.06;
            letter-spacing: -0.055em;
            margin: 36px 0 20px;
            text-transform: none;
        }

        .hero-left,
        .hero-right {
            padding: 0;
            border: 0;
            background: transparent;
        }

        .hero-description {
            color: var(--page-ink);
            font-family: ui-sans-serif, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            font-size: 1.1rem;
            line-height: 1.72;
            max-width: 680px;
        }

        .hero-meta {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 2px;
            margin-top: 26px;
            border: 1px solid var(--page-line);
            border-radius: 8px;
            overflow: hidden;
            background: var(--page-line);
        }

        .meta-item {
            border: 0;
            padding: 14px 16px;
            background: var(--page-bg);
        }

        .meta-label {
            color: var(--page-muted);
            font-size: 12px;
            letter-spacing: 0;
            margin-bottom: 6px;
            text-transform: none;
        }

        .meta-value {
            font-family: ui-sans-serif, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            font-size: 14px;
            font-weight: 500;
        }

        .marquee-container {
            width: min(100%, 720px);
            margin: 0 auto 24px;
            padding: 0;
            overflow: visible;
            border: 0;
            background: transparent;
            color: var(--page-muted);
        }

        .marquee {
            display: flex;
            animation: none;
            flex-wrap: wrap;
            gap: 8px;
        }

        .marquee-content {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            padding-right: 0;
            white-space: normal;
        }

        .marquee-content + .marquee-content {
            display: none;
        }

        .marquee-item {
            border-radius: 5px;
            padding: 3px 7px;
            background: var(--page-soft);
            font-family: ui-sans-serif, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            font-size: 12px;
            letter-spacing: 0;
            text-transform: none;
        }

        .section {
            border: 0;
            padding: 22px 0 4px;
        }

        .section-header {
            border: 0;
            padding: 0;
            background: transparent;
            justify-content: flex-start;
            gap: 10px;
            margin-bottom: 8px;
        }

        .section-title {
            font-family: ui-sans-serif, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            font-size: 1.28rem;
            font-weight: 700;
            letter-spacing: -0.02em;
            text-transform: none;
        }

        .section-count {
            border-radius: 5px;
            padding: 2px 7px;
            background: var(--page-soft);
            color: var(--page-muted);
            font-family: ui-sans-serif, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            font-size: 12px;
            line-height: 1.4;
        }

        .projects-list {
            display: flex;
            flex-direction: column;
            gap: 2px;
        }

        .project-item {
            display: grid;
            grid-template-columns: 34px minmax(120px, 0.7fr) 1.6fr 24px;
            gap: 14px;
            align-items: start;
            border: 0;
            border-radius: 6px;
            padding: 9px 8px;
            transition: background 0.18s ease;
        }

        .project-item:hover {
            background: var(--page-hover);
        }

        .project-number {
            color: var(--page-muted);
            font-family: 'Space Mono', monospace;
            font-size: 12px;
            line-height: 1.8;
        }

        .project-name {
            font-family: ui-sans-serif, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            font-size: 15px;
            font-weight: 650;
            line-height: 1.55;
            letter-spacing: 0;
            text-transform: none;
        }

        .project-description {
            color: var(--page-muted);
            font-family: ui-sans-serif, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            font-size: 14px;
            line-height: 1.65;
        }

        .project-arrow {
            color: var(--page-muted);
            font-size: 15px;
            line-height: 1.5;
            transition: transform 0.18s ease;
        }

        .project-tech {
            display: flex;
            flex-wrap: wrap;
            gap: 6px;
            margin-top: 7px;
        }

        .tech-tag {
            border: 0;
            border-radius: 5px;
            padding: 2px 6px;
            background: var(--page-soft);
            color: var(--page-muted);
            font-size: 11px;
            letter-spacing: 0;
            text-transform: none;
        }

        .skills-section {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
        }

        .skill-item {
            border: 0;
            border-radius: 5px;
            padding: 4px 8px;
            background: var(--page-soft);
            color: var(--page-muted);
            font-family: ui-sans-serif, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            font-size: 13px;
            letter-spacing: 0;
            text-align: left;
            transition: background 0.18s ease, color 0.18s ease;
        }

        .skill-item:hover {
            background: #e8e8e5;
            color: var(--page-ink);
        }

        .work-grid {
            display: flex;
            flex-direction: column;
            gap: 2px;
        }

        .work-item {
            border: 0;
            border-radius: 6px;
            padding: 10px 8px;
            transition: background 0.18s ease;
        }

        .work-item:hover {
            background: var(--page-hover);
        }

        .work-item:hover a {
            color: var(--page-ink);
        }

        .work-company {
            font-family: ui-sans-serif, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            font-size: 15px;
            font-weight: 650;
            margin-bottom: 3px;
            text-transform: none;
        }

        .work-role {
            color: var(--page-muted);
            font-size: 13px;
            letter-spacing: 0;
            margin-bottom: 8px;
            opacity: 1;
            text-transform: none;
        }

        .work-description {
            color: var(--page-muted);
            font-family: ui-sans-serif, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            font-size: 14px;
            line-height: 1.65;
        }

        .work-link {
            display: inline-block;
            margin-top: 8px;
            color: var(--page-muted);
            font-size: 13px;
            text-decoration: none;
        }

        .footer {
            border-top: 1px solid var(--page-line);
            background: var(--page-bg);
            color: var(--page-muted);
            padding: 36px 40px;
        }

        .footer-content {
            width: min(100%, 720px);
            grid-template-columns: 1fr 1fr;
            gap: 28px;
        }

        .footer-content > div:first-child {
            display: none;
        }

        .footer-section-title,
        .footer-link {
            color: var(--page-muted);
            font-family: ui-sans-serif, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            font-size: 13px;
            letter-spacing: 0;
            text-transform: none;
        }

        @media (max-width: 760px) {
            #main-content {
                padding: 44px 20px 80px;
            }

            .hero-title {
                margin-top: 20px;
            }

            .hero-meta,
            .project-item,
            .footer-content {
                grid-template-columns: 1fr;
            }

            .project-number {
                display: none;
            }

            .project-arrow {
                justify-self: start;
            }
        }
    </style>
    </Fragment>

    <!-- Hero -->
    <main id="main-content">
    <section class="hero">
        <div class="hero-left">
            <h1 class="hero-title">
                <span>IMRAN</span>
            </h1>
        </div>
        <div class="hero-right">
            <div>
                <p class="hero-description">
                    Senior Full Stack Developer specializing in building data-intensive applications.
                </p>
                <div class="hero-meta">
                    <div class="meta-item">
                        <div class="meta-label">Location</div>
                        <div class="meta-value">Bengaluru, India</div>
                    </div>
                    <div class="meta-item">
                        <div class="meta-label">Current Role</div>
                        <div class="meta-value">@ Thoughtseed</div>
                    </div>
                    <div class="meta-item">
                        <div class="meta-label">Specialization</div>
                        <div class="meta-value">Full Stack</div>
                    </div>
                    <div class="meta-item">
                        <div class="meta-label">Status</div>
                        <div class="meta-value">Available</div>
                    </div>
                </div>
            </div>
        </div>
    </section>
    
    <!-- Skills Marquee -->
    <div class="marquee-container">
        <div class="marquee">
            <div class="marquee-content">
                {[...skills, ...skills].map((skill) => (
                    <span class="marquee-item">{skill}</span>
                ))}
            </div>
            <div class="marquee-content">
                {[...skills, ...skills].map((skill) => (
                    <span class="marquee-item">{skill}</span>
                ))}
            </div>
        </div>
    </div>
    
    <!-- Projects -->
    <section class="section">
        <div class="section-header">
            <h2 class="section-title">Selected Work</h2>
            <span class="section-count">03</span>
        </div>
        <div class="projects-list">
            {projects.map((project) => (
                <a href={project.url} target="_blank" class="project-item">
                    <span class="project-number">{project.number}</span>
                    <h3 class="project-name">{project.name}</h3>
                    <div>
                        <p class="project-description">{project.description}</p>
                        <div class="project-tech">
                            {project.tech.map((t) => (
                                <span class="tech-tag">{t}</span>
                            ))}
                        </div>
                    </div>
                    <span class="project-arrow">↗</span>
                </a>
            ))}
        </div>
    </section>
    
    <!-- Skills Grid -->
    <section class="section">
        <div class="section-header">
            <h2 class="section-title">Technologies</h2>
        </div>
        <div class="skills-section">
            {skills.map((skill) => (
                <div class="skill-item">{skill}</div>
            ))}
        </div>
    </section>
    
    <!-- Work Experience -->
    <section class="section">
        <div class="section-header">
            <h2 class="section-title">Experience</h2>
        </div>
        <div class="work-grid">
            <div class="work-item">
                <h3 class="work-company">Thoughtseed</h3>
                <p class="work-role">Senior Full Stack Developer</p>
                <p class="work-description">
                    Building innovative web applications and data-intensive systems with cutting-edge technologies.
                </p>
                <a href="https://www.thoughtseed.space/" target="_blank" class="work-link">
                    Visit Website →
                </a>
            </div>
            <div class="work-item">
                <h3 class="work-company">Freelance</h3>
                <p class="work-role">Independent Contractor</p>
                <p class="work-description">
                    Developing custom software solutions for clients. Full-stack web applications and system architecture.
                </p>
            </div>
        </div>
    </section>
    
    </main>
</Layout>
