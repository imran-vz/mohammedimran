---
import Layout from '../../layouts/Layout.astro';
import {
	buildBreadcrumbSchema,
	buildFaqSchema,
	buildServiceSchema,
} from '../../config/schema';
import { siteMeta } from '../../config/siteMeta';
import { getHirePage, hirePages } from '../../data/hire-pages';

const { slug } = Astro.params;
const page = getHirePage(slug!);

if (!page) {
	return new Response(null, { status: 404, statusText: 'Not Found' });
}

const canonicalUrl = `${siteMeta.siteUrl}/hire/${page.slug}`;

const serviceSchema = buildServiceSchema({
	title: page.title,
	description: page.metaDescription,
	canonicalUrl,
	skills: page.skills,
	isLocal: page.slug.includes('bengaluru'),
});

const faqSchema = buildFaqSchema(page.faq);

const breadcrumbSchema = buildBreadcrumbSchema([
	{ name: 'Home', url: siteMeta.siteUrl },
	{ name: page.title, url: canonicalUrl },
]);
---

<Layout title={page.metaTitle} description={page.metaDescription} canonical={canonicalUrl}>
	<Fragment slot="head">
		<script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
		<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
		<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
	</Fragment>

	<main class="flex-1 px-4 py-12 sm:px-6 lg:px-8">
		<div class="mx-auto max-w-4xl">
			<!-- Breadcrumbs -->
			<nav aria-label="Breadcrumb" class="mb-8">
				<ol class="flex items-center gap-2 text-sm text-skin-base/60">
					<li><a href="/" class="hover:text-skin-accent transition-colors">Home</a></li>
					<li class="before:content-['/'] before:mx-2 text-skin-base/40">{page.title}</li>
				</ol>
			</nav>

			<!-- Hero -->
			<header class="mb-16">
				<h1
					class="mb-6 text-4xl font-bold text-skin-base sm:text-5xl lg:text-6xl leading-tight"
				>
					{page.headline}
				</h1>
				<p class="max-w-3xl text-lg text-skin-base/70 leading-relaxed">
					{page.intro}
				</p>
				<div class="mt-8 flex flex-wrap gap-4">
					<a
						href="mailto:mohammedimran86992@gmail.com"
						class="inline-flex items-center gap-2 rounded-lg bg-skin-accent px-6 py-3 font-semibold text-white transition-all hover:scale-105 hover:shadow-lg hover:shadow-skin-accent/30"
					>
						Get in Touch
					</a>
					<a
						href="/projects"
						class="inline-flex items-center gap-2 rounded-lg border border-skin-accent/50 px-6 py-3 font-semibold text-skin-accent transition-all hover:bg-skin-accent hover:text-white"
					>
						View All Projects
					</a>
				</div>
			</header>

			<!-- Why Hire Me -->
			<section class="mb-16">
				<h2 class="mb-8 text-2xl font-bold text-skin-base sm:text-3xl">
					{page.whyHireMe.title}
				</h2>
				<div class="grid gap-6 sm:grid-cols-2">
					{
						page.whyHireMe.points.map((point) => (
							<div class="rounded-xl border border-skin-border/50 bg-skin-card p-6 transition-all hover:border-skin-accent/30 hover:shadow-lg hover:shadow-skin-accent/5">
								<h3 class="mb-3 text-lg font-bold text-skin-base">{point.heading}</h3>
								<p class="text-sm text-skin-base/70 leading-relaxed">{point.text}</p>
							</div>
						))
					}
				</div>
			</section>

			<!-- Projects -->
			<section class="mb-16">
				<h2 class="mb-8 text-2xl font-bold text-skin-base sm:text-3xl">
					Relevant Projects
				</h2>
				<div class="space-y-6">
					{
						page.projects.map((project) => (
							<a
								href={project.url}
								target="_blank"
								rel="noopener noreferrer"
								class="group block rounded-xl border border-skin-border/50 bg-skin-card p-6 sm:p-8 transition-all hover:border-skin-accent/30 hover:shadow-lg hover:shadow-skin-accent/5"
							>
								<div class="flex items-start justify-between gap-4">
									<div>
										<h3 class="mb-2 text-xl font-bold text-skin-base group-hover:text-skin-accent transition-colors">
											{project.name}
										</h3>
										<p class="mb-4 text-sm text-skin-base/70 leading-relaxed">
											{project.description}
										</p>
										<div class="flex flex-wrap gap-2">
											{project.tech.map((t) => (
												<span class="rounded-full bg-skin-accent/10 px-3 py-1 text-xs font-medium text-skin-accent">
													{t}
												</span>
											))}
										</div>
									</div>
									<span class="text-skin-base/30 group-hover:text-skin-accent transition-colors text-xl">
										↗
									</span>
								</div>
							</a>
						))
					}
				</div>
			</section>

			<!-- Skills -->
			<section class="mb-16">
				<h2 class="mb-8 text-2xl font-bold text-skin-base sm:text-3xl">
					Technical Skills
				</h2>
				<div class="grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-4">
					{
						page.skills.map((skill) => (
							<div class="rounded-lg border border-skin-border/50 bg-skin-card px-4 py-3 text-center text-sm font-medium text-skin-base">
								{skill}
							</div>
						))
					}
				</div>
			</section>

			<!-- FAQ -->
			<section class="mb-16">
				<h2 class="mb-8 text-2xl font-bold text-skin-base sm:text-3xl">
					Frequently Asked Questions
				</h2>
				<div class="space-y-4">
					{
						page.faq.map((item) => (
							<details class="group rounded-xl border border-skin-border/50 bg-skin-card p-6">
								<summary class="cursor-pointer text-lg font-semibold text-skin-base list-none flex items-center justify-between">
									{item.question}
									<span class="ml-4 text-skin-accent transition-transform group-open:rotate-45">
										+
									</span>
								</summary>
								<p class="mt-4 text-skin-base/70 leading-relaxed">{item.answer}</p>
							</details>
						))
					}
				</div>
			</section>

			<!-- CTA -->
			<section class="rounded-2xl border border-skin-accent/30 bg-skin-card p-8 text-center sm:p-12">
				<h2 class="mb-4 text-2xl font-bold text-skin-base sm:text-3xl">
					Ready to Work Together?
				</h2>
				<p class="mb-6 text-skin-base/70">
					Let's discuss your project requirements. I'm available for freelance work and contract engagements.
				</p>
				<div class="flex flex-wrap justify-center gap-4">
					<a
						href="mailto:mohammedimran86992@gmail.com"
						class="inline-flex items-center gap-2 rounded-lg bg-skin-accent px-6 py-3 font-semibold text-white transition-all hover:scale-105 hover:shadow-lg hover:shadow-skin-accent/30"
					>
						Email Me
					</a>
					<a
						href="https://www.linkedin.com/in/m0hammedimran/"
						target="_blank"
						rel="noopener noreferrer"
						class="inline-flex items-center gap-2 rounded-lg border border-skin-accent/50 px-6 py-3 font-semibold text-skin-accent transition-all hover:bg-skin-accent hover:text-white"
					>
						LinkedIn
					</a>
				</div>
			</section>
		</div>
	</main>
</Layout>
