---
import Layout from '../layouts/Layout.astro';

const skills = {
	expert: ['REACT', 'TYPESCRIPT', 'JAVASCRIPT'],
	proficient: ['GOLANG', 'NODE.JS', 'NEXT.JS', 'TAILWIND CSS', 'GIT'],
	familiar: ['PYTHON', 'DOCKER', 'POSTGRESQL', 'MONGODB', 'REDIS', 'AWS'],
};

const allSkills = [...skills.expert, ...skills.proficient, ...skills.familiar];

const experience = [
	{
		year: '2020 — PRESENT',
		title: '5+ YEARS FULL STACK',
		description: 'Building scalable web applications with modern technologies and best practices',
	},
	{
		year: 'PRIMARY STACK',
		title: 'REACT, TS, GO',
		description: 'Deep expertise in frontend and backend development with these core technologies',
	},
	{
		year: 'LOCATION',
		title: 'BENGALURU, INDIA',
		description: 'Available for remote collaboration worldwide',
	},
];
---

<Layout
    title="Skills & Expertise | Imran | React, TypeScript, GoLang Developer"
    description="Imran's technical skills and expertise. 5+ years experience in React, TypeScript, GoLang, and modern web development. Based in Bengaluru, India."
    canonical="https://imran.codes/skills"
>
    <main id="main-content">
        <!-- Hero -->
        <section class="page-hero">
            <div class="page-hero-left">
                <h1 class="page-hero-title">SKILLS</h1>
            </div>
            <div class="page-hero-right">
                <p class="page-hero-breadcrumb">
                    <a href="/">Home</a> / Skills
                </p>
                <p class="page-hero-description">
                    5+ years building scalable, performant web applications. Specialized in React, TypeScript, and GoLang.
                </p>
            </div>
        </section>

        <!-- Experience Overview -->
        <section class="section">
            <div class="section-header">
                <h2 class="section-title">Experience</h2>
            </div>
            <div class="experience-grid">
                {experience.map((item) => (
                    <div class="experience-item">
                        <span class="experience-label">{item.year}</span>
                        <h3 class="experience-title">{item.title}</h3>
                        <p class="experience-description">{item.description}</p>
                    </div>
                ))}
            </div>
        </section>

        <!-- Expert Skills -->
        <section class="section">
            <div class="section-header">
                <h2 class="section-title">Expert</h2>
                <span class="section-count">{String(skills.expert.length).padStart(2, '0')}</span>
            </div>
            <div class="skills-grid skills-grid--3">
                {skills.expert.map((skill) => (
                    <div class="skill-cell skill-cell--expert">{skill}</div>
                ))}
            </div>
        </section>

        <!-- Proficient Skills -->
        <section class="section">
            <div class="section-header">
                <h2 class="section-title">Proficient</h2>
                <span class="section-count">{String(skills.proficient.length).padStart(2, '0')}</span>
            </div>
            <div class="skills-grid skills-grid--5">
                {skills.proficient.map((skill) => (
                    <div class="skill-cell">{skill}</div>
                ))}
            </div>
        </section>

        <!-- Familiar Skills -->
        <section class="section">
            <div class="section-header">
                <h2 class="section-title">Familiar</h2>
                <span class="section-count">{String(skills.familiar.length).padStart(2, '0')}</span>
            </div>
            <div class="skills-grid skills-grid--6">
                {skills.familiar.map((skill) => (
                    <div class="skill-cell">{skill}</div>
                ))}
            </div>
        </section>

        <!-- All Technologies Marquee -->
        <div class="marquee-container">
            <div class="marquee">
                <div class="marquee-content">
                    {[...allSkills, ...allSkills].map((skill) => (
                        <span class="marquee-item">{skill}</span>
                    ))}
                </div>
                <div class="marquee-content">
                    {[...allSkills, ...allSkills].map((skill) => (
                        <span class="marquee-item">{skill}</span>
                    ))}
                </div>
            </div>
        </div>

        <!-- Open Source -->
        <section class="section">
            <div class="section-header">
                <h2 class="section-title">Open Source</h2>
            </div>
            <div class="opensource-grid">
                <div class="opensource-item">
                    <h3 class="opensource-title">GITHUB</h3>
                    <p class="opensource-description">Active contributor to open source projects. Check out my repositories and contributions.</p>
                    <a href="https://github.com/imran-vz" target="_blank" rel="noopener noreferrer" class="opensource-link">
                        VIEW PROFILE ↗
                    </a>
                </div>
                <div class="opensource-item">
                    <h3 class="opensource-title">PROJECTS</h3>
                    <p class="opensource-description">Hand-picked showcase of my best work built with Go, TypeScript, Rust, and modern web technologies.</p>
                    <a href="/projects" class="opensource-link">
                        VIEW PROJECTS →
                    </a>
                </div>
            </div>
        </section>

        <!-- CTA -->
        <section class="cta-section">
            <div class="cta-content">
                <h2 class="cta-title">LET'S WORK TOGETHER</h2>
                <p class="cta-text">Interested in collaboration? Reach out and let's build something amazing.</p>
                <div class="cta-links">
                    <a href="mailto:mohammedimran86992@gmail.com" class="cta-link">EMAIL ME →</a>
                    <a href="https://www.linkedin.com/in/m0hammedimran/" target="_blank" rel="noopener noreferrer" class="cta-link">LINKEDIN ↗</a>
                </div>
            </div>
        </section>
    </main>
</Layout>

<style>
    .page-hero {
        display: grid;
        grid-template-columns: 1fr 1fr;
        border-bottom: 4px solid var(--black);
    }

    @media (max-width: 900px) {
        .page-hero {
            grid-template-columns: 1fr;
        }
    }

    .page-hero-left {
        border-right: 4px solid var(--black);
        padding: 60px 40px;
        display: flex;
        flex-direction: column;
        justify-content: center;
        background: var(--yellow);
    }

    @media (max-width: 900px) {
        .page-hero-left {
            border-right: none;
            border-bottom: 4px solid var(--black);
        }
    }

    .page-hero-title {
        font-family: 'Anton', sans-serif;
        font-size: clamp(5rem, 18vw, 14rem);
        line-height: 0.9;
        letter-spacing: -0.02em;
        text-transform: uppercase;
    }

    .page-hero-right {
        padding: 60px 40px;
        display: flex;
        flex-direction: column;
        justify-content: center;
        gap: 30px;
    }

    .page-hero-breadcrumb {
        font-size: 12px;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        color: var(--gray);
    }

    .page-hero-breadcrumb a:hover {
        color: var(--black);
    }

    .page-hero-description {
        font-size: 1.25rem;
        line-height: 1.8;
        max-width: 500px;
    }

    /* Experience */
    .experience-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
    }

    @media (max-width: 700px) {
        .experience-grid {
            grid-template-columns: 1fr;
        }
    }

    .experience-item {
        padding: 40px;
        border-right: 2px solid var(--black);
        transition: all 0.3s;
    }

    .experience-item:last-child {
        border-right: none;
    }

    @media (max-width: 700px) {
        .experience-item {
            border-right: none;
            border-bottom: 2px solid var(--black);
        }
        .experience-item:last-child {
            border-bottom: none;
        }
    }

    .experience-item:hover {
        background: var(--yellow);
    }

    .experience-label {
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        color: var(--gray);
    }

    .experience-item:hover .experience-label {
        color: var(--black);
    }

    .experience-title {
        font-family: 'Anton', sans-serif;
        font-size: 2rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-top: 12px;
        margin-bottom: 12px;
    }

    .experience-description {
        font-size: 13px;
        line-height: 1.8;
        color: var(--gray);
    }

    .experience-item:hover .experience-description {
        color: var(--black);
    }

    /* Skills Grids */
    .skills-grid {
        display: grid;
    }

    .skills-grid--3 {
        grid-template-columns: repeat(3, 1fr);
    }

    .skills-grid--5 {
        grid-template-columns: repeat(5, 1fr);
    }

    .skills-grid--6 {
        grid-template-columns: repeat(6, 1fr);
    }

    @media (max-width: 900px) {
        .skills-grid--5,
        .skills-grid--6 {
            grid-template-columns: repeat(3, 1fr);
        }
    }

    @media (max-width: 500px) {
        .skills-grid--3,
        .skills-grid--5,
        .skills-grid--6 {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    .skill-cell {
        padding: 40px 20px;
        border-right: 2px solid var(--black);
        border-bottom: 2px solid var(--black);
        text-align: center;
        transition: all 0.3s;
        font-family: 'Anton', sans-serif;
        font-size: 1.5rem;
        letter-spacing: 0.1em;
    }

    .skill-cell:last-child {
        border-right: none;
    }

    .skill-cell:hover {
        background: var(--black);
        color: var(--yellow);
    }

    .skill-cell--expert {
        font-size: 2rem;
        padding: 60px 20px;
    }

    .skill-cell--expert:hover {
        background: var(--yellow);
        color: var(--black);
    }

    /* Marquee */
    .marquee-container {
        background: var(--black);
        color: var(--white);
        padding: 20px 0;
        overflow: hidden;
        border-bottom: 4px solid var(--black);
    }

    .marquee {
        display: flex;
        animation: marquee 40s linear infinite;
    }

    .marquee-content {
        display: flex;
        gap: 60px;
        padding-right: 60px;
        white-space: nowrap;
    }

    .marquee-item {
        font-family: 'Anton', sans-serif;
        font-size: 2rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
    }

    @keyframes marquee {
        0% { transform: translateX(0); }
        100% { transform: translateX(-50%); }
    }

    /* Open Source */
    .opensource-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
    }

    @media (max-width: 700px) {
        .opensource-grid {
            grid-template-columns: 1fr;
        }
    }

    .opensource-item {
        padding: 60px 40px;
        border-right: 2px solid var(--black);
        transition: all 0.3s;
    }

    .opensource-item:last-child {
        border-right: none;
    }

    @media (max-width: 700px) {
        .opensource-item {
            border-right: none;
            border-bottom: 2px solid var(--black);
        }
        .opensource-item:last-child {
            border-bottom: none;
        }
    }

    .opensource-item:hover {
        background: var(--yellow);
    }

    .opensource-title {
        font-family: 'Anton', sans-serif;
        font-size: 3rem;
        text-transform: uppercase;
        margin-bottom: 16px;
    }

    .opensource-description {
        font-size: 14px;
        line-height: 1.8;
        color: var(--gray);
        margin-bottom: 20px;
    }

    .opensource-item:hover .opensource-description {
        color: var(--black);
    }

    .opensource-link {
        display: inline-block;
        font-size: 12px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        text-decoration: underline;
        text-underline-offset: 4px;
    }

    /* CTA */
    .cta-section {
        border-bottom: 4px solid var(--black);
        background: var(--red);
        color: var(--white);
    }

    .cta-content {
        padding: 80px 40px;
        text-align: center;
        max-width: 800px;
        margin: 0 auto;
    }

    .cta-title {
        font-family: 'Anton', sans-serif;
        font-size: 4rem;
        text-transform: uppercase;
        margin-bottom: 16px;
    }

    .cta-text {
        font-size: 14px;
        line-height: 1.8;
        opacity: 0.8;
        margin-bottom: 40px;
    }

    .cta-links {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 16px;
    }

    .cta-link {
        padding: 16px 32px;
        border: 3px solid var(--white);
        font-size: 12px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        transition: all 0.3s;
    }

    .cta-link:hover {
        background: var(--white);
        color: var(--black);
    }

    @media (max-width: 600px) {
        .page-hero-left { padding: 32px 20px; }
        .page-hero-right { padding: 28px 20px; }
        .page-hero-description { font-size: 1rem; }
        .experience-item { padding: 24px 20px; }
        .experience-title { font-size: 1.5rem; }
        .skill-cell { padding: 24px 12px; font-size: 1.1rem; }
        .skill-cell--expert { padding: 40px 12px; font-size: 1.5rem; }
        .opensource-item { padding: 32px 20px; }
        .opensource-title { font-size: 2rem; }
        .cta-content { padding: 40px 20px; }
        .cta-title { font-size: 2.5rem; }
    }
</style>
