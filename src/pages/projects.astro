---
import Layout from '../layouts/Layout.astro';
import type { FeaturedProject } from '../utils/fetch-featured-projects';

let projects: FeaturedProject[] = [];

try {
	const response = await fetch(new URL('/api/featured-projects', Astro.url));
	projects = await response.json();
} catch (error) {
	console.log('Error fetching featured projects:', error);
}
---

<Layout
    title="Projects | Imran | Full Stack Developer Portfolio"
    description="Explore Imran's portfolio of React, TypeScript, and GoLang projects. Open source contributions and full-stack development work."
    canonical="https://imran.codes/projects"
>
    <main id="main-content">
        <!-- Hero -->
        <section class="page-hero">
            <div class="page-hero-left">
                <h1 class="page-hero-title">PROJECTS</h1>
            </div>
            <div class="page-hero-right">
                <p class="page-hero-breadcrumb">
                    <a href="/">Home</a> / Projects
                </p>
                <p class="page-hero-description">
                    Hand-picked showcase of my best open-source work. Built with Go, TypeScript, Rust, and modern web technologies.
                </p>
                <a href="https://github.com/imran-vz" target="_blank" rel="noopener noreferrer" class="github-cta">
                    VIEW ALL ON GITHUB ↗
                </a>
            </div>
        </section>

        <!-- Projects -->
        <section class="section">
            <div class="section-header">
                <h2 class="section-title">Featured Work</h2>
                <span class="section-count">{String(projects.length).padStart(2, '0')}</span>
            </div>

            {projects.length > 0 ? (
                <div class="projects-list">
                    {projects.map((project, i) => (
                        <a href={project.url} target="_blank" rel="noopener noreferrer" class="project-item">
                            <span class="project-number">{String(i + 1).padStart(2, '0')}</span>
                            <h3 class="project-name">{project.name}</h3>
                            <div>
                                <p class="project-description">{project.description}</p>
                                <div class="project-meta-row">
                                    {project.languages && project.languages.length > 0 && (
                                        <div class="project-tech">
                                            {project.languages.slice(0, 4).map((lang) => (
                                                <span class="tech-tag">{lang.name}</span>
                                            ))}
                                        </div>
                                    )}
                                    <div class="project-stats">
                                        <span class="stat-item">★ {project.stars}</span>
                                        <span class="stat-item">⑂ {project.forks}</span>
                                    </div>
                                </div>
                            </div>
                            <span class="project-arrow">↗</span>
                        </a>
                    ))}
                </div>
            ) : (
                <div class="empty-state">
                    <p class="empty-title">NO PROJECTS LOADED</p>
                    <p class="empty-text">
                        Check back soon or visit my <a href="https://github.com/imran-vz" target="_blank" rel="noopener noreferrer" style="text-decoration: underline; text-underline-offset: 3px;">GitHub profile</a>.
                    </p>
                </div>
            )}
        </section>

        <!-- CTA -->
        <section class="cta-section">
            <div class="cta-grid">
                <div class="cta-left">
                    <h2 class="cta-title">LET'S COLLABORATE</h2>
                    <p class="cta-text">Interested in working together? Check out my skills or get in touch.</p>
                </div>
                <div class="cta-links">
                    <a href="/skills" class="cta-link">VIEW SKILLS →</a>
                    <a href="mailto:mohammedimran86992@gmail.com" class="cta-link">CONTACT ME →</a>
                </div>
            </div>
        </section>
    </main>
</Layout>

<style>
    .page-hero {
        display: grid;
        grid-template-columns: 1fr 1fr;
        border-bottom: 4px solid var(--black);
    }

    @media (max-width: 900px) {
        .page-hero {
            grid-template-columns: 1fr;
        }
    }

    .page-hero-left {
        border-right: 4px solid var(--black);
        padding: 60px 40px;
        display: flex;
        flex-direction: column;
        justify-content: center;
        background: var(--yellow);
    }

    @media (max-width: 900px) {
        .page-hero-left {
            border-right: none;
            border-bottom: 4px solid var(--black);
        }
    }

    .page-hero-title {
        font-family: 'Anton', sans-serif;
        font-size: clamp(5rem, 18vw, 14rem);
        line-height: 0.9;
        letter-spacing: -0.02em;
        text-transform: uppercase;
    }

    .page-hero-right {
        padding: 60px 40px;
        display: flex;
        flex-direction: column;
        justify-content: center;
        gap: 30px;
    }

    .page-hero-breadcrumb {
        font-size: 12px;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        color: var(--gray);
    }

    .page-hero-breadcrumb a:hover {
        color: var(--black);
    }

    .page-hero-description {
        font-size: 1.25rem;
        line-height: 1.8;
        max-width: 500px;
    }

    .github-cta {
        display: inline-block;
        padding: 12px 24px;
        border: 3px solid var(--black);
        font-size: 12px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        transition: all 0.3s;
        align-self: flex-start;
    }

    .github-cta:hover {
        background: var(--black);
        color: var(--yellow);
    }

    .projects-list {
        display: flex;
        flex-direction: column;
    }

    .project-item {
        display: grid;
        grid-template-columns: 100px 1fr 2fr auto;
        gap: 40px;
        padding: 40px;
        border-bottom: 2px solid var(--black);
        transition: all 0.3s;
        align-items: center;
    }

    @media (max-width: 900px) {
        .project-item {
            grid-template-columns: 1fr;
            gap: 20px;
        }
    }

    .project-item:last-child {
        border-bottom: none;
    }

    .project-item:hover {
        background: var(--yellow);
    }

    .project-number {
        font-family: 'Anton', sans-serif;
        font-size: 4rem;
        color: var(--gray);
        transition: color 0.3s;
    }

    .project-item:hover .project-number {
        color: var(--black);
    }

    .project-name {
        font-family: 'Anton', sans-serif;
        font-size: 2.5rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .project-description {
        font-size: 14px;
        line-height: 1.8;
        color: var(--gray);
    }

    .project-item:hover .project-description {
        color: var(--black);
    }

    .project-meta-row {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 20px;
        margin-top: 15px;
    }

    .project-tech {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
    }

    .tech-tag {
        padding: 5px 12px;
        border: 2px solid var(--black);
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 0.1em;
    }

    .project-stats {
        display: flex;
        gap: 16px;
        font-size: 13px;
        font-weight: 700;
    }

    .project-arrow {
        font-size: 2rem;
        transition: transform 0.3s;
    }

    .project-item:hover .project-arrow {
        transform: translate(10px, -10px);
    }

    .empty-state {
        padding: 80px 40px;
        text-align: center;
    }

    .empty-title {
        font-family: 'Anton', sans-serif;
        font-size: 3rem;
        text-transform: uppercase;
        color: var(--gray);
        margin-bottom: 20px;
    }

    .empty-text {
        font-size: 14px;
        color: var(--gray);
    }

    .cta-section {
        border-bottom: 4px solid var(--black);
    }

    .cta-grid {
        display: grid;
        grid-template-columns: 2fr 1fr;
        gap: 40px;
        padding: 60px 40px;
        align-items: center;
    }

    @media (max-width: 700px) {
        .cta-grid {
            grid-template-columns: 1fr;
            gap: 30px;
        }
    }

    .cta-title {
        font-family: 'Anton', sans-serif;
        font-size: 3rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-bottom: 12px;
    }

    .cta-text {
        font-size: 14px;
        line-height: 1.8;
        color: var(--gray);
    }

    .cta-links {
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .cta-link {
        padding: 16px 24px;
        border: 3px solid var(--black);
        font-size: 12px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        text-align: center;
        transition: all 0.3s;
    }

    .cta-link:hover {
        background: var(--black);
        color: var(--yellow);
    }

    @media (max-width: 600px) {
        .page-hero-left { padding: 32px 20px; }
        .page-hero-right { padding: 28px 20px; }
        .page-hero-description { font-size: 1rem; }
        .project-item { padding: 20px; }
        .project-number { font-size: 1.75rem; }
        .project-name { font-size: 1.5rem; }
        .cta-grid { padding: 40px 20px; }
        .cta-title { font-size: 2rem; }
    }

    #main-content,
    .page-hero,
    .section,
    .cta-section {
        width: min(100%, 720px);
        margin: 0 auto;
    }

    .page-hero {
        display: block;
        border-bottom: 0;
        padding-bottom: 28px;
    }

    .page-hero-left,
    .page-hero-right {
        display: block;
        border: 0;
        padding: 0;
        background: transparent;
    }

    .page-hero-title {
        font-family: Georgia, 'Times New Roman', serif;
        font-size: clamp(3rem, 9vw, 5.5rem);
        line-height: 1.06;
        letter-spacing: -0.055em;
        margin: 36px 0 20px;
        text-transform: none;
    }

    .page-hero-breadcrumb,
    .page-hero-description,
    .project-description,
    .cta-text,
    .stat-item,
    .empty-text {
        color: var(--page-muted);
        font-family: ui-sans-serif, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        letter-spacing: 0;
        text-transform: none;
    }

    .page-hero-description {
        max-width: 680px;
        font-size: 1.1rem;
        line-height: 1.72;
    }

    .github-cta,
    .cta-link {
        border: 0;
        border-radius: 6px;
        padding: 7px 10px;
        background: var(--page-soft);
        color: var(--page-ink);
        font-family: ui-sans-serif, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        font-size: 13px;
        letter-spacing: 0;
        text-transform: none;
    }

    .github-cta:hover,
    .cta-link:hover,
    .project-item:hover {
        background: var(--page-hover);
        color: var(--page-ink);
    }

    .projects-list {
        gap: 2px;
    }

    .project-item {
        grid-template-columns: 34px minmax(120px, 0.7fr) 1.6fr 24px;
        gap: 14px;
        align-items: start;
        border: 0;
        border-radius: 6px;
        padding: 9px 8px;
        transition: background 0.18s ease;
    }

    .project-number {
        color: var(--page-muted);
        font-family: 'Space Mono', monospace;
        font-size: 12px;
        line-height: 1.8;
    }

    .project-name,
    .cta-title,
    .empty-title {
        font-family: ui-sans-serif, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        font-size: 15px;
        font-weight: 650;
        line-height: 1.55;
        letter-spacing: 0;
        text-transform: none;
    }

    .tech-tag {
        border: 0;
        border-radius: 5px;
        padding: 2px 6px;
        background: var(--page-soft);
        color: var(--page-muted);
        font-size: 11px;
        letter-spacing: 0;
        text-transform: none;
    }

    .cta-section {
        border-bottom: 0;
    }

    .cta-grid {
        grid-template-columns: 1fr;
        gap: 12px;
        padding: 22px 0 4px;
    }

    @media (max-width: 760px) {
        .project-item {
            grid-template-columns: 1fr;
        }

        .project-number {
            display: none;
        }
    }
</style>
